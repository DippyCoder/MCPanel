{
  "name": "mcpanel",
  "version": "1.0.2",
  "description": "Minecraft Server Panel",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --config.directories.output=dist/win",
    "build:mac": "electron-builder --mac --config.directories.output=dist/mac",
    "build:linux": "electron-builder --linux AppImage deb rpm --config.directories.output=dist/linux",
    "build:linux:appimage": "electron-builder --linux AppImage --config.directories.output=dist/linux",
    "build:linux:deb": "electron-builder --linux deb --config.directories.output=dist/linux",
    "build:linux:rpm": "electron-builder --linux rpm --config.directories.output=dist/linux"
  },
  "author": {
    "name": "DippyCoder",
    "email": "planewriter255@gmail.com"
  },
  "build": {
    "appId": "com.dippycoder.mcpanel",
    "productName": "MCPanel",
    "icon": "src/assets/icon.png",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "backend/**/*", "src/**/*", "node_modules/**/*"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": ["AppImage", "deb", "rpm"] }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "archiver": "^6.0.0",
    "tree-kill": "^1.2.2"
  }
}
